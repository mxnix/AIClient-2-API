TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=@your_channel

# Optional: if you want to reuse an existing post
TELEGRAM_MESSAGE_ID=

# Optional overrides. In most Docker setups they are auto-detected from /configs.
PROJECT_ID=
GEMINI_OAUTH_CREDS_FILE_PATH=
GEMINI_OAUTH_CREDS_BASE64=
GEMINI_BASE_URL=
GEMINI_CHECK_MODEL=gemini-3.1-pro-preview
GEMINI_FIXED_IPS=

MONITOR_INTERVAL_MS=600000
PROBE_TIMEOUT_MS=45000
PROBE_CONCURRENCY=4

MONITOR_ASSETS_DIR=/assets
MONITOR_STATE_FILE=/data/state.json
MONITOR_AUDIT_LOG_FILE=/data/ip-status.log
CONFIG_JSON_PATH=/configs/config.json
PROVIDER_POOLS_FILE_PATH=/configs/provider_pools.json
